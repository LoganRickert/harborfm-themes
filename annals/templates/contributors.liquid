<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Contributors | {{ podcast.title | escape }}</title>
</head>
<body class="annals-theme annals-page-{{ page }}">
  <div class="ann-shell">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
    <main class="ann-page">
      <header class="ann-page-head">
        <p class="ann-eyebrow"><span class="ann-folio">Folio III</span> Scholarly archive, open stacks</p>
        <h1 class="ann-title ann-display">Contributors</h1>
        <p class="ann-lede">Hosts, guests, and voices named in the annals.</p>
      </header>
      <section class="ann-panel">
        {% if show.cast %}{% if cast.hosts.size > 0 or cast.guests.size > 0 %}
        <div class="ann-cast-grid">
          {% for host in cast.hosts %}
          <article class="ann-cast-card">
            {% if host.image_url != "" %}<img src="{{ host.image_url | escape }}" alt="" />{% endif %}
            <p class="ann-cast-name">{{ host.name | escape }}</p>
            <p class="ann-cast-role"><span class="ann-folio">Host</span> {% if host.role != "" %}{{ host.role | escape }}{% else %}Primary{% endif %}</p>
            {% if host.description != "" %}<p class="ann-cast-desc">{{ host.description | escape }}</p>{% endif %}
          </article>
          {% endfor %}
          {% for guest in cast.guests %}
          <article class="ann-cast-card">
            {% if guest.image_url != "" %}<img src="{{ guest.image_url | escape }}" alt="" />{% endif %}
            <p class="ann-cast-name">{{ guest.name | escape }}</p>
            <p class="ann-cast-role"><span class="ann-folio">Guest</span> {% if guest.role != "" %}{{ guest.role | escape }}{% else %}Interview{% endif %}</p>
            {% if guest.description != "" %}<p class="ann-cast-desc">{{ guest.description | escape }}</p>{% endif %}
          </article>
          {% endfor %}
        </div>
        {% endif %}{% else %}
        <p class="ann-lede">Enable cast on the show in HarborFM to populate this page.</p>
        {% endif %}
      </section>
    </main>
    {% render '_footer', podcast: podcast, urls: urls, theme: theme %}
  </div>
</body>
</html>
