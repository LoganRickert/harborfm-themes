<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Endowments | {{ podcast.title | escape }}</title>
</head>
<body class="annals-theme annals-page-{{ page }}">
  <div class="ann-shell">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
    <main class="ann-page">
      <header class="ann-page-head">
        <p class="ann-eyebrow"><span class="ann-folio">Folio IV</span> Scholarly archive, open stacks</p>
        <h1 class="ann-title ann-display">Endowments</h1>
        <p class="ann-lede">Patron the archive and keep new volumes on the shelf.</p>
      </header>
      <section class="ann-panel">
        {% if show.funding %}{% if funding_links.size > 0 %}
        <div class="ann-fund-row">
          {% for f in funding_links %}
          <a class="ann-fund-chip" href="{{ f.url | escape }}">{{ f.text | escape }}</a>
          {% endfor %}
        </div>
        {% endif %}{% else %}
        <p class="ann-lede">Add funding links in HarborFM to unlock this page.</p>
        {% endif %}
      </section>
    </main>
    {% render '_footer', podcast: podcast, urls: urls, theme: theme %}
  </div>
</body>
</html>
