<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>{{ podcast.title | escape }} | {{ site.name | escape }}</title>
</head>
<body class="annals-theme annals-page-{{ page }}">
  <div class="ann-shell">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
    <main class="ann-page">
      <section class="ann-hero">
        <img class="ann-hero__scene" src="{{ urls.theme_asset_base }}/images/hero.jpg" alt="" />
        <div class="ann-hero__panel">
          <p class="ann-eyebrow"><span class="ann-folio">Folio I</span> Scholarly archive, open stacks</p>
          {% if podcast.artwork_url != "" %}
          <img class="ann-hero__cover" src="{{ podcast.artwork_url | escape }}" alt="" width="144" height="144" />
          {% endif %}
          <h1 class="ann-title ann-display">{{ podcast.title | escape }}</h1>
          {% if show.podcast_description %}{% if podcast.description != "" %}<p class="ann-lede">{{ podcast.description | escape }}</p>{% endif %}{% endif %}
          <div class="ann-actions">
            <button type="button" class="ann-btn ann-btn--fill" data-harborfm-action="subscribe"><i class="fa-solid fa-circle-plus" aria-hidden="true"></i> Subscribe</button>
            <a class="ann-btn ann-btn--line" data-harborfm-action="feed"><i class="fa-solid fa-rss" aria-hidden="true"></i> Feed</a>
            <button type="button" class="ann-btn ann-btn--line" data-harborfm-action="share"><i class="fa-solid fa-share-nodes" aria-hidden="true"></i> Share</button>
            <button type="button" class="ann-btn ann-btn--line" data-harborfm-action="message"><i class="fa-solid fa-envelope" aria-hidden="true"></i> Message</button>
            <button type="button" class="ann-btn ann-btn--line" data-harborfm-action="alerts"><i class="fa-solid fa-bell" aria-hidden="true"></i> Alerts</button>
          </div>
          <p class="ann-lede"><a class="ann-catalogue-link" href="{{ urls.pages.podcast }}">Open Catalogue &rarr;</a></p>
        </div>
      </section>

      <section class="ann-strip" aria-label="Archive plates">
        <figure class="ann-strip__item">
          <img src="{{ urls.theme_asset_base }}/images/a.jpg" alt="" />
          <figcaption><span class="ann-folio">a</span> Maps</figcaption>
        </figure>
        <figure class="ann-strip__item">
          <img src="{{ urls.theme_asset_base }}/images/b.jpg" alt="" />
          <figcaption><span class="ann-folio">b</span> Library</figcaption>
        </figure>
        <figure class="ann-strip__item">
          <img src="{{ urls.theme_asset_base }}/images/c.jpg" alt="" />
          <figcaption><span class="ann-folio">c</span> Letters</figcaption>
        </figure>
      </section>
    </main>
    {% render '_footer', podcast: podcast, urls: urls, theme: theme %}
  </div>
</body>
</html>
