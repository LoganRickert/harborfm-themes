<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Page not found | {{ podcast.title | escape }}</title>
</head>
<body class="annals-theme annals-page-{{ page }}">
  <div class="ann-shell">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
    <main class="ann-page">
      <header class="ann-page-head">
        <p class="ann-eyebrow"><span class="ann-folio">Misfiled</span> Scholarly archive, open stacks</p>
        <h1 class="ann-title ann-display">Volume not in the register</h1>
      </header>
      <section class="ann-panel">
        <p class="ann-lede">That call number does not exist in this collection. Return to the reading room.</p>
        <div class="ann-actions">
          <a class="ann-btn ann-btn--fill" href="{{ urls.home }}">Return to reading room</a>
        </div>
      </section>
    </main>
    {% render '_footer', podcast: podcast, urls: urls, theme: theme %}
  </div>
</body>
</html>
