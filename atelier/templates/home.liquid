<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>{{ podcast.title | escape }} | {{ site.name | escape }}</title>
</head>
<body class="atelier-theme atelier-page-{{ page }}">
  {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <header class="quote-hero">
    <p class="eyebrow">Interviews in sharp light</p>
    <h1 class="display">{{ podcast.title | escape }}</h1>
    {% if show.podcast_description %}{% if podcast.description != "" %}<p class="lede">{{ podcast.description | escape }}</p>{% endif %}{% endif %}
    <div class="action-row">
      <button type="button" class="btn-ink" data-harborfm-action="subscribe"><i class="fa-solid fa-circle-plus" aria-hidden="true"></i> Subscribe</button>
      <a class="btn-outline-ink" data-harborfm-action="feed"><i class="fa-solid fa-rss" aria-hidden="true"></i> Feed</a>
      <button type="button" class="btn-outline-ink" data-harborfm-action="share"><i class="fa-solid fa-share-nodes" aria-hidden="true"></i> Share</button>
    </div>
  </header>
  <div class="cols">
    <div>
      <section class="panel"><h2>Features</h2>{% render 'harborfm/search' %}{% render 'harborfm/episodes' %}</section>
    </div>
    <aside class="cols-side">
      <img src="{{ urls.theme_asset_base }}/images/hero.jpg" alt="" />
      <div class="portraits" style="margin-top:0.5rem">
        <img src="{{ urls.theme_asset_base }}/images/a.jpg" alt="" /><img src="{{ urls.theme_asset_base }}/images/b.jpg" alt="" /><img src="{{ urls.theme_asset_base }}/images/c.jpg" alt="" />
      </div>
    </aside>
  </div>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</body>
</html>
