<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Muses & editors | {{ podcast.title | escape }}</title>
</head>
<body class="atelier-theme atelier-page-{{ page }}">
  {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <main class="main">
      <header>
        <p class="eyebrow">Interviews in sharp light</p>
        <h1 class="title display">Muses & editors</h1>
      </header>
      <section class="panel">
        <p class="lede">Faces and bylines shaping each sitting.</p>
        {% if show.cast %}{% if cast.hosts.size > 0 or cast.guests.size > 0 %}
        <div class="muse-grid">
          {% for host in cast.hosts %}
          <div class="muse-card">
            {% if host.image_url != "" %}<img src="{{ host.image_url | escape }}" alt="" />{% endif %}
            <p class="muse-name">{{ host.name | escape }}</p>
            <p class="muse-role">{% if host.role != "" %}{{ host.role | escape }}{% else %}Host{% endif %}</p>
            {% if host.description != "" %}<p class="muse-desc">{{ host.description | escape }}</p>{% endif %}
          </div>
          {% endfor %}
          {% for guest in cast.guests %}
          <div class="muse-card">
            {% if guest.image_url != "" %}<img src="{{ guest.image_url | escape }}" alt="" />{% endif %}
            <p class="muse-name">{{ guest.name | escape }}</p>
            <p class="muse-role">{% if guest.role != "" %}{{ guest.role | escape }}{% else %}Guest{% endif %}</p>
            {% if guest.description != "" %}<p class="muse-desc">{{ guest.description | escape }}</p>{% endif %}
          </div>
          {% endfor %}
        </div>
        {% endif %}{% else %}<p class="lede">Enable cast on the show in HarborFM to populate this page.</p>{% endif %}
      </section>
    </main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</body>
</html>
