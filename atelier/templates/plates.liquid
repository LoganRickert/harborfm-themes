<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Print plates | {{ podcast.title | escape }}</title>
</head>
<body class="atelier-theme atelier-page-{{ page }}">
  {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <main class="main plates">
    <header class="plates__head">
      <p class="eyebrow">Interviews in sharp light</p>
      <h1 class="title display">Print plates</h1>
      <p class="plates__lede">Portrait stills in the Atelier package, licensed from Unsplash. Each plate links to the original.</p>
    </header>

    <ul class="plate-wall">
      <li class="plate">
        <a class="plate__frame" href="https://unsplash.com/photos/mans-grey-and-black-shirt-ILip77SbmOE" rel="noopener noreferrer">
          <img src="{{ urls.theme_asset_base }}/images/hero.jpg" alt="Portrait of a person in a grey and black shirt" />
        </a>
        <div class="plate__meta">
          <p class="plate__name">Lead portrait</p>
          <p class="plate__file">hero.jpg · Home, Lookbook, gallery preview</p>
          <p class="plate__by">
            Photo by
            <a href="https://unsplash.com/@albertdera" rel="noopener noreferrer">Albert Dera</a>
            on
            <a href="https://unsplash.com/photos/mans-grey-and-black-shirt-ILip77SbmOE" rel="noopener noreferrer">Unsplash</a>
          </p>
        </div>
      </li>

      <li class="plate">
        <a class="plate__frame" href="https://unsplash.com/photos/woman-in-black-scoop-neck-shirt-CGKYNN3uuVo" rel="noopener noreferrer">
          <img src="{{ urls.theme_asset_base }}/images/a.jpg" alt="Portrait of a person in a black scoop-neck shirt" />
        </a>
        <div class="plate__meta">
          <p class="plate__name">Studio A</p>
          <p class="plate__file">a.jpg · Home, Lookbook</p>
          <p class="plate__by">
            Photo by
            <a href="https://unsplash.com/@filipp_roman_photography" rel="noopener noreferrer">Filipp Romanovski</a>
            on
            <a href="https://unsplash.com/photos/woman-in-black-scoop-neck-shirt-CGKYNN3uuVo" rel="noopener noreferrer">Unsplash</a>
          </p>
        </div>
      </li>

      <li class="plate">
        <a class="plate__frame" href="https://unsplash.com/photos/man-in-black-jacket-wearing-brown-scarf-and-black-framed-eyeglasses-M58gP7tAM54" rel="noopener noreferrer">
          <img src="{{ urls.theme_asset_base }}/images/b.jpg" alt="Portrait of a person in a jacket, scarf, and glasses" />
        </a>
        <div class="plate__meta">
          <p class="plate__name">Studio B</p>
          <p class="plate__file">b.jpg · Home, Lookbook</p>
          <p class="plate__by">
            Photo by
            <a href="https://unsplash.com/@kapischka" rel="noopener noreferrer">Paul Kapischka</a>
            on
            <a href="https://unsplash.com/photos/man-in-black-jacket-wearing-brown-scarf-and-black-framed-eyeglasses-M58gP7tAM54" rel="noopener noreferrer">Unsplash</a>
          </p>
        </div>
      </li>

      <li class="plate">
        <a class="plate__frame" href="https://unsplash.com/photos/woman-wearing-black-sunglasses-and-black-camisole-_fvUcz1H6EY" rel="noopener noreferrer">
          <img src="{{ urls.theme_asset_base }}/images/c.jpg" alt="Portrait of a person wearing sunglasses" />
        </a>
        <div class="plate__meta">
          <p class="plate__name">Studio C</p>
          <p class="plate__file">c.jpg · Home, Lookbook</p>
          <p class="plate__by">
            Photo by
            <a href="https://unsplash.com/@zvandrei" rel="noopener noreferrer">Andrey Zvyagintsev</a>
            on
            <a href="https://unsplash.com/photos/woman-wearing-black-sunglasses-and-black-camisole-_fvUcz1H6EY" rel="noopener noreferrer">Unsplash</a>
          </p>
        </div>
      </li>

      <li class="plate">
        <a class="plate__frame" href="https://unsplash.com/photos/man-wearing-black-notched-lapel-suit-jacket-in-focus-photography-WMD64tMfc4k" rel="noopener noreferrer">
          <img src="{{ urls.theme_asset_base }}/images/d.jpg" alt="Portrait of a person in a dark suit jacket" />
        </a>
        <div class="plate__meta">
          <p class="plate__name">Suit plate</p>
          <p class="plate__file">d.jpg · Profile, Features, Lookbook</p>
          <p class="plate__by">
            Photo by
            <a href="https://unsplash.com/@alimorshedlou" rel="noopener noreferrer">Ali Morshedlou</a>
            on
            <a href="https://unsplash.com/photos/man-wearing-black-notched-lapel-suit-jacket-in-focus-photography-WMD64tMfc4k" rel="noopener noreferrer">Unsplash</a>
          </p>
        </div>
      </li>
    </ul>

  </main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</body>
</html>
