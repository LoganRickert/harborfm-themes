<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Editor’s letter | {{ podcast.title | escape }}</title>
</head>
<body class="atelier-theme atelier-page-{{ page }}">
  {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <main class="main">
      <header>
        <p class="eyebrow">Interviews in sharp light</p>
        <h1 class="title display">Editor’s letter</h1>
      </header>
      <section class="panel">
        <p class="lede">The magazine’s point of view, in print-friendly prose.</p>
        {% if show.podcast_description %}{% if podcast.description != "" %}
          <p class="lede">{{ podcast.description | escape }}</p>
        {% else %}<p class="lede">Add a podcast description in HarborFM to fill this page.</p>{% endif %}
        {% else %}<p class="lede">Podcast description is hidden in page customizations.</p>{% endif %}
        {% if show.author %}{% if podcast.author_name != "" %}<p class="lede">Hosted by {{ podcast.author_name | escape }}.</p>{% endif %}{% endif %}
      </section>
      <img class="theme-figure" src="{{ urls.theme_asset_base }}/images/d.jpg" alt="" />
    </main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</body>
</html>
