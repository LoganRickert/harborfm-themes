<aside class="evidence-rail" aria-label="Case navigation">
  <div class="evidence-rail__tape" aria-hidden="true"></div>
  <div class="evidence-rail__bar">
    <a class="brand" href="{{ urls.home }}">{{ podcast.title | escape }}</a>
    <details class="nav-menu">
      <summary class="nav-menu__toggle" aria-label="Menu"><span class="nav-menu__icon" aria-hidden="true"></span></summary>
      <nav aria-label="Show pages">
        <a href="{{ urls.home }}"{% if page == "home" %} aria-current="page"{% endif %}><span class="evidence-label">Exhibit A</span> Briefing</a>
        <a href="{{ urls.pages.podcast }}"{% if page == "podcast" %} aria-current="page"{% endif %}><span class="evidence-label">Exhibit B</span> Case log</a>
        <a href="{{ urls.pages.persons }}"{% if page == "persons" %} aria-current="page"{% endif %}><span class="evidence-label">Exhibit C</span> Persons</a>
        <a href="{{ urls.pages.tips }}"{% if page == "tips" %} aria-current="page"{% endif %}><span class="evidence-label">Exhibit D</span> Tips</a>
        <a href="{{ urls.pages.channels }}"{% if page == "channels" %} aria-current="page"{% endif %}><span class="evidence-label">Exhibit E</span> Channels</a>
        <a href="{{ urls.pages.exhibits }}"{% if page == "exhibits" %} aria-current="page"{% endif %}><span class="evidence-label">Exhibit F</span> Exhibits</a>
      </nav>
    </details>
  </div>
</aside>
