<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Page not found | {{ podcast.title | escape }}</title>
</head>
<body class="casefile-theme casefile-page-{{ page }}">
  <div class="dossier">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
    <div class="dossier-main">
      <header class="page-head page-head--404">
        <p class="eyebrow">err=404</p>
        <h1 class="title display">File not found</h1>
        <p class="lede">No exhibit matches that path. Return to the briefing room.</p>
        <div class="action-row">
          <a class="btn-stamp" href="{{ urls.home }}">Back to briefing</a>
        </div>
      </header>

      {% render '_footer', podcast: podcast, urls: urls, theme: theme %}
    </div>
  </div>
</body>
</html>
