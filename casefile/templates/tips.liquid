<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Tips | {{ podcast.title | escape }}</title>
</head>
<body class="casefile-theme casefile-page-{{ page }}">
  <div class="dossier">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
    <div class="dossier-main">
      <header class="page-head">
        <p class="eyebrow">Noir dossier, open file</p>
        <h1 class="title display">Tips</h1>
        <p class="lede">Fund the investigation and keep new episodes on the docket.</p>
      </header>

      <section class="panel dossier-panel">
        {% if show.funding %}{% if funding_links.size > 0 %}
        <div class="channel-row">
          {% for f in funding_links %}
          <a class="channel-tag channel-fund" href="{{ f.url | escape }}">{{ f.text | escape }}</a>
          {% endfor %}
        </div>
        {% endif %}{% else %}
        <p class="lede">Add funding links in HarborFM to unlock this page.</p>
        {% endif %}
      </section>

      <img class="theme-figure" src="{{ urls.theme_asset_base }}/images/d.jpg" alt="" />

      {% render '_footer', podcast: podcast, urls: urls, theme: theme %}
    </div>
  </div>
</body>
</html>
