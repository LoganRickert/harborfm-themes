<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>{{ episode.title | escape }} | {{ podcast.title | escape }}</title>
</head>
<body class="castellan-theme castellan-page-{{ page }}">
  <div class="shell">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
    {% render '_pathhead', title: episode.title, podcast: podcast, urls: urls %}
    <main class="main">
      <nav class="ep-crumbs ep-crumbs--keep" aria-label="Breadcrumb">
        <a href="{{ urls.home }}">Ramparts</a><span aria-hidden="true">/</span>
        <a href="{{ urls.pages.podcast }}">Chronicle</a><span aria-hidden="true">/</span>
        <span>Dispatch</span>
      </nav>
      <p class="ep-keep__dek">A sealed dispatch from the keep. Break the wax when you are ready to listen.</p>
      <section class="ep-player ep-player--keep">{% render 'harborfm/player' %}</section>
      {% if show.episode_description %}{% if episode.description != "" %}
      <section class="panel panel--parchment"><h2>Margin notes</h2><p class="lede">{{ episode.description | escape }}</p></section>
      {% endif %}{% endif %}
      {% if show.funding %}{% if funding_links.size > 0 %}
      <section class="panel panel--parchment">
        <h2>Offer a tithe</h2>
        <div class="tithe-row">
          {% for f in funding_links %}<a class="tithe-tag" href="{{ f.url | escape }}">{{ f.text | escape }}</a>{% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}
      {% if show.reviews_episode %}
      <section class="panel panel--parchment reviews-block" aria-label="Court letters">
        <header class="reviews-block__head">
          <h2>Court letters</h2>
        </header>
        {% render 'harborfm/reviews' %}
      </section>
      {% endif %}
    </main>
    {% render '_footer', podcast: podcast, urls: urls, theme: theme %}
    <nav class="battlement-nav" aria-label="Show pages">
      <a href="{{ urls.home }}"{% if page == "home" %} aria-current="page"{% endif %}>Ramparts</a>
      <a href="{{ urls.pages.podcast }}"{% if page == "podcast" %} aria-current="page"{% endif %}>Chronicle</a>
      <a href="{{ urls.pages.court }}"{% if page == "court" %} aria-current="page"{% endif %}>Court</a>
      <a href="{{ urls.pages.tithes }}"{% if page == "tithes" %} aria-current="page"{% endif %}>Tithes</a>
      <a href="{{ urls.pages.reliquary }}"{% if page == "reliquary" %} aria-current="page"{% endif %}>Reliquary</a>
      <a href="{{ urls.pages.illuminations }}"{% if page == "illuminations" %} aria-current="page"{% endif %}>Illuminations</a>
    </nav>
  </div>
</body>
</html>
