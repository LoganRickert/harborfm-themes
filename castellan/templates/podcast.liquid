<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Chronicle | {{ podcast.title | escape }}</title>
</head>
<body class="castellan-theme castellan-page-{{ page }}">
  <div class="shell">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
    {% render '_pathhead', title: 'Chronicle', podcast: podcast, urls: urls %}
    <main class="main">
      <section class="panel panel--parchment chronicle-panel">
        <p class="lede">The illuminated record of this keep: what we guard and who holds the quill.</p>
        {% if podcast.artwork_url != "" %}
        <img class="chronicle-panel__art" src="{{ podcast.artwork_url | escape }}" alt="" width="168" height="168" />
        {% endif %}
        {% if show.podcast_description %}{% if podcast.description != "" %}
        <p class="lede">{{ podcast.description | escape }}</p>
        {% else %}<p class="lede">Add a podcast description in HarborFM to fill this page.</p>{% endif %}
        {% else %}<p class="lede">Podcast description is hidden in page customizations.</p>{% endif %}
        {% if show.author %}{% if podcast.author_name != "" %}<p class="lede">Recorded by {{ podcast.author_name | escape }}.</p>{% endif %}{% endif %}
      </section>
      <img class="theme-figure" src="{{ urls.theme_asset_base }}/images/a.jpg" alt="" />
    </main>
    {% render '_footer', podcast: podcast, urls: urls, theme: theme %}
    <nav class="battlement-nav" aria-label="Show pages">
      <a href="{{ urls.home }}"{% if page == "home" %} aria-current="page"{% endif %}>Ramparts</a>
      <a href="{{ urls.pages.podcast }}"{% if page == "podcast" %} aria-current="page"{% endif %}>Chronicle</a>
      <a href="{{ urls.pages.court }}"{% if page == "court" %} aria-current="page"{% endif %}>Court</a>
      <a href="{{ urls.pages.tithes }}"{% if page == "tithes" %} aria-current="page"{% endif %}>Tithes</a>
      <a href="{{ urls.pages.reliquary }}"{% if page == "reliquary" %} aria-current="page"{% endif %}>Reliquary</a>
      <a href="{{ urls.pages.illuminations }}"{% if page == "illuminations" %} aria-current="page"{% endif %}>Illuminations</a>
    </nav>
  </div>
</body>
</html>
