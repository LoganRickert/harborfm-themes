      <a href="{{ urls.pages.charter }}"{% if page == "charter" %} aria-current="page"{% endif %}>Charter</a>
      <a href="{{ urls.pages.partners }}"{% if page == "partners" %} aria-current="page"{% endif %}>Partners</a>
      <a href="{{ urls.pages.brief }}"{% if page == "brief" %} aria-current="page"{% endif %}>Brief</a>
      <a href="{{ urls.pages.underwrite }}"{% if page == "underwrite" %} aria-current="page"{% endif %}>Underwrite</a>
      <a href="{{ urls.pages.attribution }}"{% if page == "attribution" %} aria-current="page"{% endif %}>Attribution</a>
