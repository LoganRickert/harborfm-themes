<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Executive brief | {{ podcast.title | escape }}</title>
</head>
<body class="glasshouse-theme glasshouse-page-{{ page }}">
  {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <main class="main">
      <header>
        <p class="eyebrow">Leadership in clear air</p>
        <h1 class="title display">Executive brief</h1>
      </header>
      <section class="panel">
        <p class="lede">Channels, other shows, and what listeners are saying.</p>
        {% if show.podcast_description %}{% if podcast.description != "" %}<p class="lede">{{ podcast.description | escape }}</p>{% endif %}{% endif %}
      </section>
      <img class="theme-figure" src="{{ urls.theme_asset_base }}/images/hero.jpg" alt="" />

      {% if show.links %}{% if links.size > 0 %}
      <section class="panel">
        <h2>Channels</h2>
        <div class="glass-tags">
          {% for link in links %}<a class="glass-tag" href="{{ link.url | escape }}">{{ link.label | escape }}</a>{% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}
      {% if show.podroll %}{% if podroll.size > 0 %}
      <section class="panel">
        <h2>Recommended listening</h2>
        <div class="podroll-grid">
          {% for p in podroll %}
          <a class="podroll-card" href="{{ p.home_url | escape }}">
            {% if p.cover_art_url != "" %}<img src="{{ p.cover_art_url | escape }}" alt="" />{% endif %}
            <span>{{ p.title | escape }}</span>
          </a>
          {% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}
      {% if show.reviews_podcast %}
      <section class="panel reviews-block" aria-label="Board minutes">
        <header class="reviews-block__head">
          <h2>Board minutes</h2>
        </header>
        {% render 'harborfm/reviews' %}
      </section>
      {% endif %}</main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</body>
</html>
