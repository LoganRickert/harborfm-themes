<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>{{ episode.title | escape }} | {{ podcast.title | escape }}</title>
</head>
<body class="glasshouse-theme glasshouse-page-{{ page }}">
  {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <main class="main">
      <nav class="ep-crumbs ep-crumbs--glass" aria-label="Breadcrumb">
        <a href="{{ urls.home }}">Atrium</a><span aria-hidden="true">/</span>
        <a href="{{ urls.pages.podcast }}">Minutes</a><span aria-hidden="true">/</span>
        <span>Session</span>
      </nav>
      <header class="ep-mast ep-mast--glass">
        <p class="eyebrow">Session brief</p>
        <h1 class="ep-mast__title">{{ episode.title | escape }}</h1>
        <p class="ep-mast__dek">Clear-air playback for the room.</p>
      </header>
      <section class="ep-player ep-player--glass">{% render 'harborfm/player' %}</section>
      {% if show.episode_description %}{% if episode.description != "" %}
      <section class="panel"><h2>Annex</h2><p class="lede">{{ episode.description | escape }}</p></section>
      {% endif %}{% endif %}
      {% if show.funding %}{% if funding_links.size > 0 %}
      <section class="panel">
        <h2>Keep it going</h2>
        <div class="glass-tags">
          {% for f in funding_links %}<a class="glass-tag" href="{{ f.url | escape }}">{{ f.text | escape }}</a>{% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}
      {% if show.reviews_episode %}
      <section class="panel reviews-block" aria-label="Board minutes">
        <header class="reviews-block__head">
          <h2>Board minutes</h2>
        </header>
        {% render 'harborfm/reviews' %}
      </section>
      {% endif %}</main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</body>
</html>
