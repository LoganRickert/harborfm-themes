<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Page not found | {{ podcast.title | escape }}</title>
</head>
<body class="glasshouse-theme glasshouse-page-{{ page }}">
  {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <main class="main">
      <header>
        <p class="eyebrow">Directory miss</p>
        <h1 class="title display">Floor not listed</h1>
      </header>
      <section class="panel">
        <p class="lede">That suite is not in the building directory. Return to the lobby.</p>
        <div class="action-row">
          <a class="btn-cobalt" href="{{ urls.home }}">Return to lobby</a>
        </div>
      </section>
    </main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</body>
</html>
