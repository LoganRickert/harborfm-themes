      <a href="{{ urls.pages.boxoffice }}"{% if page == "boxoffice" %} aria-current="page"{% endif %}>Box Office</a>
      <a href="{{ urls.pages.premiere }}"{% if page == "premiere" %} aria-current="page"{% endif %}>Premiere</a>
      <a href="{{ urls.pages.marquee }}"{% if page == "marquee" %} aria-current="page"{% endif %}>Marquee</a>
