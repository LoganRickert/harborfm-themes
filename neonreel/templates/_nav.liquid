      <a href="{{ urls.pages.synopsis }}"{% if page == "synopsis" %} aria-current="page"{% endif %}>Synopsis</a>
      <a href="{{ urls.pages.talent }}"{% if page == "talent" %} aria-current="page"{% endif %}>Talent</a>
