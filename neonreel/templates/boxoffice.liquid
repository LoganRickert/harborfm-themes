<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Box Office | {{ podcast.title | escape }}</title>
</head>
<body class="neonreel-theme neonreel-page-{{ page }}">
  <div class="shell">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <main class="main">
      <header>
        <p class="eyebrow">Film culture after dark</p>
        <h1 class="title display">Box Office</h1>
      </header>
      <section class="panel">
        <p class="lede">Keep the projector warm. Tickets optional, tips welcome.</p>
        {% if show.funding %}{% if funding_links.size > 0 %}
        <div class="ticket-row">
          {% for f in funding_links %}<a class="ticket-tag" href="{{ f.url | escape }}">{{ f.text | escape }}</a>{% endfor %}
        </div>
        {% endif %}{% else %}<p class="lede">Add funding links in HarborFM to unlock this page.</p>{% endif %}
      </section>
    </main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</div>
</body>
</html>
