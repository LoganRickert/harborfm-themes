<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>{{ podcast.title | escape }} | {{ site.name | escape }}</title>
</head>
<body class="neonreel-theme neonreel-page-{{ page }}">
  <div class="shell">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <header class="hero-bleed" style="background-image: url('{{ urls.theme_asset_base }}/images/hero.jpg');">
      <div class="inner">
        <p class="eyebrow">Film culture after dark</p>
        <h1 class="title display">{{ podcast.title | escape }}</h1>
        {% if show.podcast_description %}{% if podcast.description != "" %}<p class="lede">{{ podcast.description | escape }}</p>{% endif %}{% endif %}
        <div class="action-row">
          <button type="button" class="btn-pop" data-harborfm-action="subscribe"><i class="fa-solid fa-circle-plus" aria-hidden="true"></i> Subscribe</button>
          <a class="btn-cyan" data-harborfm-action="feed"><i class="fa-solid fa-rss" aria-hidden="true"></i> Feed</a>
          <button type="button" class="btn-cyan" data-harborfm-action="share"><i class="fa-solid fa-share-nodes" aria-hidden="true"></i> Share</button>
        </div>
        <p class="lede"><a class="reel-link" href="{{ urls.pages.podcast }}">Open Reel &rarr;</a></p>
      </div>
    </header>
    <main class="main">
      <div class="strip">
        <img src="{{ urls.theme_asset_base }}/images/a.jpg" alt="" />
        <img src="{{ urls.theme_asset_base }}/images/b.jpg" alt="" />
        <img src="{{ urls.theme_asset_base }}/images/c.jpg" alt="" />
      </div>
    </main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</div>
</body>
</html>
