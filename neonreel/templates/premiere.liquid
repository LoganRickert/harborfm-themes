<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Premiere circuit | {{ podcast.title | escape }}</title>
</head>
<body class="neonreel-theme neonreel-page-{{ page }}">
  <div class="shell">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <main class="main">
      <header>
        <p class="eyebrow">Film culture after dark</p>
        <h1 class="title display">Premiere circuit</h1>
      </header>
      <section class="panel">
        <p class="lede">Where to catch openings, clips, and the red-carpet feed.</p>
        {% if show.links %}{% if links.size > 0 %}
        <div class="ticket-row">
          {% for link in links %}<a class="ticket-tag ticket-tag-{{ link.group }}" href="{{ link.url | escape }}">{{ link.label | escape }}</a>{% endfor %}
        </div>
        {% endif %}{% else %}<p class="lede">Add listen-on / social links in HarborFM to fill this page.</p>{% endif %}
      </section>
      {% if show.podroll %}{% if podroll.size > 0 %}
      <section class="panel">
        <h2>Also in rotation</h2>
        <div class="podroll-grid">
          {% for p in podroll %}
          <a class="podroll-card" href="{{ p.home_url | escape }}">
            {% if p.cover_art_url != "" %}<img src="{{ p.cover_art_url | escape }}" alt="" />{% endif %}
            <span>{{ p.title | escape }}</span>
          </a>
          {% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}
      {% if show.reviews_podcast %}
      <section class="panel reviews-block" aria-label="Audience cards">
        <header class="reviews-block__head">
          <h2>Audience cards</h2>
        </header>
        {% render 'harborfm/reviews' %}
      </section>
      {% endif %}
    </main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</div>
</body>
</html>
