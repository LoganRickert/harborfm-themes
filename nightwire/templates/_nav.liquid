<aside class="terminal">
  <div class="terminal-bar">
    <a class="brand" href="{{ urls.home }}">{{ podcast.title | escape }}</a>
    <details class="nav-menu">
      <summary class="nav-menu__toggle" aria-label="Menu"><span class="nav-menu__icon" aria-hidden="true"></span></summary>
      <nav aria-label="Show pages">
        <a href="{{ urls.home }}"{% if page == "home" %} aria-current="page"{% endif %}>Frequency</a>
        <a href="{{ urls.pages.podcast }}"{% if page == "podcast" %} aria-current="page"{% endif %}>Cleartext</a>
        <a href="{{ urls.pages.capture }}"{% if page == "capture" %} aria-current="page"{% endif %}>Capture</a>
      </nav>
    </details>
  </div>
</aside>
