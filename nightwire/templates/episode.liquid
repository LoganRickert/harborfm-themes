<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>{{ episode.title | escape }} | {{ podcast.title | escape }}</title>
</head>
<body class="nightwire-theme nightwire-page-{{ page }}">
  <div class="hud">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <div class="stage">
      <div class="glitch" style="top:12%" aria-hidden="true"></div>
      <div class="glitch g2" aria-hidden="true"></div>

      <header class="ep-mast ep-mast--wire">
        <p class="ep-mast__prompt" aria-hidden="true">&gt; decode --channel episode</p>
        <p class="eyebrow">Underground signal, open channel</p>
      </header>
      <nav class="ep-crumbs ep-crumbs--wire" aria-label="Breadcrumb">
        <a href="{{ urls.home }}">frequency/</a>
        <a href="{{ urls.pages.podcast }}">cleartext/</a>
        <span>decode</span>
      </nav>
      <section class="ep-player ep-player--wire">{% render 'harborfm/player' %}</section>
      {% if show.episode_description %}{% if episode.description != "" %}
      <section class="panel"><h2>Packet dump</h2><p class="lede">{{ episode.description | escape }}</p></section>
      {% endif %}{% endif %}
      {% if show.funding %}{% if funding_links.size > 0 %}
      <section class="panel">
        <h2>Keep it going</h2>
        <div class="channel-list">
          {% for f in funding_links %}<a class="channel-chip channel-fund" href="{{ f.url | escape }}">{{ f.text | escape }}</a>{% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}
      {% if show.reviews_episode %}
      <section class="panel reviews-block" aria-label="Intercepted chatter">
        <header class="reviews-block__head">
          <h2>Intercepted chatter</h2>
        </header>
        {% render 'harborfm/reviews' %}
      </section>
      {% endif %}{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</div>
  </div>
</body>
</html>
