<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Cleartext dossier | {{ podcast.title | escape }}</title>
</head>
<body class="nightwire-theme nightwire-page-{{ page }}">
  <div class="hud">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <div class="stage">
      <div class="glitch" style="top:12%" aria-hidden="true"></div>
      <div class="glitch g2" aria-hidden="true"></div>

      <header>
        <p class="eyebrow">Underground signal, open channel</p>
        <h1 class="title display">Cleartext dossier</h1>
      </header>
      <section class="panel">
        <p class="lede">Readable brief when the cipher can rest. The live signal log is on Frequency.</p>
        {% if show.podcast_description %}{% if podcast.description != "" %}<p class="lede">{{ podcast.description | escape }}</p>{% endif %}{% endif %}
        {% if show.author %}{% if podcast.author_name != "" %}<p class="lede">Hosted by {{ podcast.author_name | escape }}.</p>{% endif %}{% endif %}
      </section>
      <img class="theme-figure" src="{{ urls.theme_asset_base }}/images/d.jpg" alt="" />

      {% if show.cast %}{% if cast.hosts.size > 0 or cast.guests.size > 0 %}
      <section class="panel cleartext-grid">
        <h2>Operators on file</h2>
        <div class="node-list">
          {% for host in cast.hosts %}
          <div class="node-card">
            {% if host.image_url != "" %}<img src="{{ host.image_url | escape }}" alt="" />{% endif %}
            <p class="node-name">{{ host.name | escape }}</p>
            <p class="node-role">{% if host.role != "" %}{{ host.role | escape }}{% else %}Host{% endif %}</p>
            {% if host.description != "" %}<p class="node-desc">{{ host.description | escape }}</p>{% endif %}
          </div>
          {% endfor %}
          {% for guest in cast.guests %}
          <div class="node-card">
            {% if guest.image_url != "" %}<img src="{{ guest.image_url | escape }}" alt="" />{% endif %}
            <p class="node-name">{{ guest.name | escape }}</p>
            <p class="node-role">{% if guest.role != "" %}{{ guest.role | escape }}{% else %}Guest{% endif %}</p>
            {% if guest.description != "" %}<p class="node-desc">{{ guest.description | escape }}</p>{% endif %}
          </div>
          {% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}

      <div class="cleartext-split">
        {% if show.links %}{% if links.size > 0 %}
        <section class="panel">
          <h2>Open channels</h2>
          <div class="channel-list">
            {% for link in links %}<a class="channel-chip channel-{{ link.group }}" href="{{ link.url | escape }}">{{ link.label | escape }}</a>{% endfor %}
          </div>
        </section>
        {% endif %}{% endif %}

        {% if show.funding %}{% if funding_links.size > 0 %}
        <section class="panel">
          <h2>Fund the frequency</h2>
          <div class="channel-list">
            {% for f in funding_links %}<a class="channel-chip channel-fund" href="{{ f.url | escape }}">{{ f.text | escape }}</a>{% endfor %}
          </div>
        </section>
        {% endif %}{% endif %}
      </div>

      {% if show.reviews_podcast %}
      <section class="panel reviews-block" aria-label="Intercepted chatter">
        <header class="reviews-block__head">
          <h2>Intercepted chatter</h2>
        </header>
        {% render 'harborfm/reviews' %}
      </section>
      {% endif %}{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</div>
  </div>
</body>
</html>
