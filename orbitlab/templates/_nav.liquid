<header class="topnav">
  <a class="brand topnav-brand" href="{{ urls.home }}">{{ podcast.title | escape }}</a>
  <details class="nav-menu">
    <summary class="nav-menu__toggle" aria-label="Menu"><span class="nav-menu__icon" aria-hidden="true"></span></summary>
    <nav aria-label="Show pages">
      <a href="{{ urls.home }}"{% if page == "home" %} aria-current="page"{% endif %}>Console</a>
      <a href="{{ urls.pages.podcast }}"{% if page == "podcast" %} aria-current="page"{% endif %}>Dossier</a>
      <a href="{{ urls.pages.briefing }}"{% if page == "briefing" %} aria-current="page"{% endif %}>Briefing</a>
      <a href="{{ urls.pages.channels }}"{% if page == "channels" %} aria-current="page"{% endif %}>Channels</a>
      <a href="{{ urls.pages.sources }}"{% if page == "sources" %} aria-current="page"{% endif %}>Sources</a>
    </nav>
  </details>
</header>
