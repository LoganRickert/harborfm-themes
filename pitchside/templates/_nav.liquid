<div class="scorebar">
  <a class="brand" href="{{ urls.home }}"><strong>{{ podcast.title | escape }}</strong></a>
  <details class="nav-menu">
    <summary class="nav-menu__toggle" aria-label="Menu"><span class="nav-menu__icon" aria-hidden="true"></span></summary>
    <nav aria-label="Show pages">
      <a href="{{ urls.home }}"{% if page == "home" %} aria-current="page"{% endif %}>Kickoff</a>
      <a href="{{ urls.pages.podcast }}"{% if page == "podcast" %} aria-current="page"{% endif %}>Clubhouse</a>
      <a href="{{ urls.pages.stills }}"{% if page == "stills" %} aria-current="page"{% endif %}>Stills</a>
    </nav>
  </details>
</div>
