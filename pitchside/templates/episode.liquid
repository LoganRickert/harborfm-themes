<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>{{ episode.title | escape }} | {{ podcast.title | escape }}</title>
</head>
<body class="pitchside-theme pitchside-page-{{ page }}">
  <div class="shell">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <main class="main">
      <div class="ep-mast ep-mast--pitch" aria-label="Matchday">
        <span class="ep-mast__badge">LIVE</span>
        <p class="ep-mast__line">Matchday tape · no fluff</p>
      </div>
      <nav class="ep-crumbs ep-crumbs--pitch" aria-label="Breadcrumb">
        <a href="{{ urls.home }}">Kickoff</a><span aria-hidden="true">›</span>
        <a href="{{ urls.pages.podcast }}">Clubhouse</a><span aria-hidden="true">›</span>
        <span>Tape</span>
      </nav>
      <section class="ep-player ep-player--pitch">{% render 'harborfm/player' %}</section>
      {% if show.episode_description %}{% if episode.description != "" %}
      <section class="panel"><h2>Match notes</h2><p class="lede">{{ episode.description | escape }}</p></section>
      {% endif %}{% endif %}
      {% if show.funding %}{% if funding_links.size > 0 %}
      <section class="panel">
        <h2>Keep it going</h2>
        <div class="tag-list">
          {% for f in funding_links %}<a class="tag tag-fund" href="{{ f.url | escape }}">{{ f.text | escape }}</a>{% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}
      {% if show.reviews_episode %}
      <section class="panel reviews-block" aria-label="From the terraces">
        <header class="reviews-block__head">
          <h2>From the terraces</h2>
        </header>
        {% render 'harborfm/reviews' %}
      </section>
      {% endif %}</main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</div>
</body>
</html>
