<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Clubhouse | {{ podcast.title | escape }}</title>
</head>
<body class="pitchside-theme pitchside-page-{{ page }}">
  <div class="shell">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <main class="main">
      <header>
        <p class="eyebrow">Match-day talk, no fluff</p>
        <h1 class="title display">Clubhouse</h1>
      </header>
      <section class="panel">
        <p class="lede">Program notes, squad talk, and what the badge stands for. The fixture list lives on Kickoff.</p>
        {% if show.podcast_description %}{% if podcast.description != "" %}<p class="lede">{{ podcast.description | escape }}</p>{% endif %}{% endif %}
        {% if show.author %}{% if podcast.author_name != "" %}<p class="lede">Hosted by {{ podcast.author_name | escape }}.</p>{% endif %}{% endif %}
      </section>
      <img class="theme-figure" src="{{ urls.theme_asset_base }}/images/d.jpg" alt="" />

      {% if show.cast %}{% if cast.hosts.size > 0 or cast.guests.size > 0 %}
      <section class="panel">
        <h2>Squad sheet</h2>
        <div class="squad-grid">
          {% for host in cast.hosts %}
          <div class="squad-card">
            {% if host.image_url != "" %}<img src="{{ host.image_url | escape }}" alt="" />{% endif %}
            <p class="squad-name">{{ host.name | escape }}</p>
            <p class="squad-role">{% if host.role != "" %}{{ host.role | escape }}{% else %}Host{% endif %}</p>
            {% if host.description != "" %}<p class="squad-desc">{{ host.description | escape }}</p>{% endif %}
          </div>
          {% endfor %}
          {% for guest in cast.guests %}
          <div class="squad-card">
            {% if guest.image_url != "" %}<img src="{{ guest.image_url | escape }}" alt="" />{% endif %}
            <p class="squad-name">{{ guest.name | escape }}</p>
            <p class="squad-role">{% if guest.role != "" %}{{ guest.role | escape }}{% else %}Guest{% endif %}</p>
            {% if guest.description != "" %}<p class="squad-desc">{{ guest.description | escape }}</p>{% endif %}
          </div>
          {% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}

      <div class="clubhouse-split">
        {% if show.links %}{% if links.size > 0 %}
        <section class="panel">
          <h2>Follow the club</h2>
          <div class="tag-list">
            {% for link in links %}<a class="tag tag-{{ link.group }}" href="{{ link.url | escape }}">{{ link.label | escape }}</a>{% endfor %}
          </div>
        </section>
        {% endif %}{% endif %}
        {% if show.funding %}{% if funding_links.size > 0 %}
        <section class="panel">
          <h2>Back the team</h2>
          <div class="tag-list">
            {% for f in funding_links %}<a class="tag tag-fund" href="{{ f.url | escape }}">{{ f.text | escape }}</a>{% endfor %}
          </div>
        </section>
        {% endif %}{% endif %}
      </div>

      {% if show.reviews_podcast %}
      <section class="panel reviews-block" aria-label="From the terraces">
        <header class="reviews-block__head">
          <h2>From the terraces</h2>
        </header>
        {% render 'harborfm/reviews' %}
      </section>
      {% endif %}
    </main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</div>
</body>
</html>
