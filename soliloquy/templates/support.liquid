<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Support | {{ podcast.title | escape }}</title>
</head>
<body class="soliloquy-theme soliloquy-page-{{ page }}">
  {% render '_nav', podcast: podcast, urls: urls, page: page %}

  <main class="sol-journal sol-journal--page">
    <header class="sol-page-head">
      <p class="sol-kicker">A room for unguarded thought</p>
      <h1 class="sol-display sol-display--page">Support</h1>
      <p class="sol-lede">Keep the conversation funded and the room open.</p>
    </header>

    <section class="sol-sheet">
      {% if show.funding %}{% if funding_links.size > 0 %}
        <div class="sol-fund-row">
          {% for f in funding_links %}<a class="sol-fund-link" href="{{ f.url | escape }}">{{ f.text | escape }}</a>{% endfor %}
        </div>
      {% else %}
        <p class="sol-lede">Add funding links in HarborFM to unlock this page.</p>
      {% endif %}{% else %}
        <p class="sol-lede">Add funding links in HarborFM to unlock this page.</p>
      {% endif %}
    </section>

    <figure class="sol-aside-figure">
      <img src="{{ urls.theme_asset_base }}/images/d.jpg" alt="" />
    </figure>
  </main>

  {% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</body>
</html>
