<aside class="rail">
  <div class="rail-bar">
    <a class="brand" href="{{ urls.home }}">{{ podcast.title | escape }}</a>
    <details class="nav-menu">
      <summary class="nav-menu__toggle" aria-label="Menu"><span class="nav-menu__icon" aria-hidden="true"></span></summary>
      <nav aria-label="Show pages">
        <a href="{{ urls.home }}"{% if page == "home" %} aria-current="page"{% endif %}>Reading Room</a>
        <a href="{{ urls.pages.podcast }}"{% if page == "podcast" %} aria-current="page"{% endif %}>Catalogue</a>
        <a href="{{ urls.pages.colophon }}"{% if page == "colophon" %} aria-current="page"{% endif %}>Colophon</a>
      </nav>
    </details>
  </div>
</aside>
