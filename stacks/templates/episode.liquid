<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>{{ episode.title | escape }} | {{ podcast.title | escape }}</title>
</head>
<body class="stacks-theme stacks-page-{{ page }}">
  <div class="layout">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <div>
    <main class="page">
      <header class="ep-mast ep-mast--stacks">
        <p class="ep-mast__shelf">Shelf mark · episode</p>
        <p class="eyebrow">Ideas between the shelves</p>
      </header>
      <nav class="ep-crumbs ep-crumbs--stacks" aria-label="Breadcrumb">
        <a href="{{ urls.home }}">Reading Room</a><span aria-hidden="true">/</span>
        <a href="{{ urls.pages.podcast }}">Catalogue</a><span aria-hidden="true">/</span>
        <span>Folio</span>
      </nav>
      <section class="ep-player ep-player--stacks">{% render 'harborfm/player' %}</section>
      {% if show.episode_description %}{% if episode.description != "" %}
      <section class="panel"><h2>Marginalia</h2><p class="lede">{{ episode.description | escape }}</p></section>
      {% endif %}{% endif %}
      {% if show.funding %}{% if funding_links.size > 0 %}
      <section class="panel">
        <h2>Keep it going</h2>
        <div class="fund-list">
          {% for f in funding_links %}<a class="fund-chip" href="{{ f.url | escape }}">{{ f.text | escape }}</a>{% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}
      {% if show.reviews_episode %}
      <section class="panel reviews-block" aria-label="Marginalia">
        <header class="reviews-block__head">
          <h2>Marginalia</h2>
        </header>
        {% render 'harborfm/reviews' %}
      </section>
      {% endif %}</main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</div>
  </div>
</body>
</html>
