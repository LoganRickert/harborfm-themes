<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Trail guides | {{ podcast.title | escape }}</title>
</head>
<body class="timberline-theme timberline-page-{{ page }}">
  <div class="shell">
    {% render '_pathhead', title: 'Trail guides', podcast: podcast, urls: urls %}
    <main class="main">
      <section class="panel">
        <p class="lede">Routes worth bookmarking and where else to find us.</p>
        {% if show.links %}{% if links.size > 0 %}
        <div class="tag-row">
          {% for link in links %}<a class="tag tag-{{ link.group }}" href="{{ link.url | escape }}">{{ link.label | escape }}</a>{% endfor %}
        </div>
        {% endif %}{% else %}<p class="lede">Add listen-on / social links in HarborFM to fill this page.</p>{% endif %}
      </section>
      {% if show.podroll %}{% if podroll.size > 0 %}
      <section class="panel">
        <h2>Other trailheads</h2>
        <div class="podroll-grid">
          {% for p in podroll %}
          <a class="podroll-card" href="{{ p.home_url | escape }}">
            {% if p.cover_art_url != "" %}<img src="{{ p.cover_art_url | escape }}" alt="" />{% endif %}
            <span>{{ p.title | escape }}</span>
          </a>
          {% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}
      {% if show.reviews_podcast %}
      <section class="panel reviews-block" aria-label="Trip reports">
        <header class="reviews-block__head">
          <h2>Trip reports</h2>
        </header>
        {% render 'harborfm/reviews' %}
      </section>
      {% endif %}</main>
{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
<nav class="bottom-nav" aria-label="Show pages">
    <a href="{{ urls.home }}"{% if page == "home" %} aria-current="page"{% endif %}>Basecamp</a>
    <a href="{{ urls.pages.podcast }}"{% if page == "podcast" %} aria-current="page"{% endif %}>Trail</a>
    <a href="{{ urls.pages.guides }}"{% if page == "guides" %} aria-current="page"{% endif %}>Guides</a>
    <a href="{{ urls.pages.campfund }}"{% if page == "campfund" %} aria-current="page"{% endif %}>Camp Fund</a>
    <a href="{{ urls.pages.fieldnotes }}"{% if page == "fieldnotes" %} aria-current="page"{% endif %}>Field Notes</a>
  </nav>
  </div>
</body>
</html>
