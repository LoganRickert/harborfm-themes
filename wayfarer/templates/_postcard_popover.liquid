{% comment %}
  Full-note popover. Render outside .pc-deck. Expects: r, postcard_id.
{% endcomment %}
{% assign body_len = r.body | size %}
{% if body_len > 280 %}
  <div id="{{ postcard_id }}" popover class="pc-popover">
    <div class="pc-popover__inner">
      <p class="pc-popover__stamp" aria-label="Rating {{ r.rating }} of 5">{{ r.rating }}/5</p>
      <p class="pc-popover__body">{{ r.body | escape }}</p>
      <p class="pc-popover__address">{{ r.name | escape }}{% if r.verified %} · Verified traveler{% endif %}</p>
      <button type="button" class="pc-popover__close" popovertarget="{{ postcard_id }}" popovertargetaction="hide">Close</button>
    </div>
  </div>
{% endif %}
