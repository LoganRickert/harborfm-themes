<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>{{ episode.title | escape }} | {{ podcast.title | escape }}</title>
</head>
<body class="wayfarer-theme wayfarer-page-{{ page }}">
  <div class="journal">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <div class="content">

      <header class="ep-mast ep-mast--way">
        <span class="ep-mast__stamp" aria-hidden="true"></span>
        <p class="eyebrow script">Dispatch from the road</p>
        <p class="ep-mast__dek">Open the postcard and press play.</p>
      </header>
      <nav class="ep-crumbs ep-crumbs--way" aria-label="Breadcrumb">
        <a href="{{ urls.home }}">Trailhead</a><span aria-hidden="true">→</span>
        <a href="{{ urls.pages.podcast }}">Dispatches</a><span aria-hidden="true">→</span>
        <span>Letter</span>
      </nav>
      <section class="ep-player ep-player--way">{% render 'harborfm/player' %}</section>
      {% if show.episode_description %}{% if episode.description != "" %}
      <section class="panel"><h2>Field notes</h2><p class="lede">{{ episode.description | escape }}</p></section>
      {% endif %}{% endif %}
      {% if show.funding %}{% if funding_links.size > 0 %}
      <section class="panel">
        <h2>Keep it going</h2>
        <div class="stamp-row">
          {% for f in funding_links %}<a class="stamp stamp-fund" href="{{ f.url | escape }}">{{ f.text | escape }}</a>{% endfor %}
        </div>
      </section>
      {% endif %}{% endif %}
      {% if show.reviews_episode %}
      <section class="panel reviews-block" aria-label="Guestbook postcards">
        <header class="reviews-block__head">
          <h2>Guestbook postcards</h2>
        </header>
        {% render 'harborfm/reviews' %}
      </section>
      {% endif %}{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</div>
  </div>
</body>
</html>
