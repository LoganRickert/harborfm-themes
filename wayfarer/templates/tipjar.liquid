<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {% render '_head', accent: accent %}
  <title>Tip jar by the door | {{ podcast.title | escape }}</title>
</head>
<body class="wayfarer-theme wayfarer-page-{{ page }}">
  <div class="journal">
    {% render '_nav', podcast: podcast, urls: urls, page: page %}
  <div class="content">

      <header>
        <p class="eyebrow">Stories from the road</p>
        <h1 class="title display">Tip jar by the door</h1>
      </header>
      <section class="panel">
        <p class="lede">Fuel for the next leg of the trip.</p>
        {% if show.funding %}{% if funding_links.size > 0 %}
        <div class="stamp-row">
          {% for f in funding_links %}<a class="stamp stamp-fund" href="{{ f.url | escape }}">{{ f.text | escape }}</a>{% endfor %}
        </div>
        {% endif %}{% else %}<p class="lede">Add funding links in HarborFM to unlock this page.</p>{% endif %}
      </section>

{% render '_footer', podcast: podcast, urls: urls, theme: theme %}
</div>
  </div>
</body>
</html>
